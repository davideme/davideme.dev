---
export interface Props {
  title: string;
  description?: string;
}

const { title, description = "Davide Mendolia - CTO & Head of Engineering with 20+ years scaling platforms from prototype to Series A. Expert in fintech, mobile architecture, team leadership, and platform scaling at topi, Karumi, Tuenti." } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content={description}>
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,300;0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700;1,14..32,400&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    
    <!-- Prevent theme flash -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme') || 
                              (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
            document.documentElement.setAttribute('data-theme', savedTheme);
        })();
    </script>
</head>
<body>
    <!-- Wave animation container -->
    <div id="wave-container" class="wave-container"></div>

    <slot />

    <script>
        // Theme management
        function initTheme() {
            const savedTheme = localStorage.getItem('theme') || 
                               (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
            document.documentElement.setAttribute('data-theme', savedTheme);
            updateThemeToggle(savedTheme);
        }

        function toggleTheme() {
            const currentTheme = document.documentElement.getAttribute('data-theme');
            const newTheme = currentTheme === 'light' ? 'dark' : 'light';
            
            document.documentElement.setAttribute('data-theme', newTheme);
            localStorage.setItem('theme', newTheme);
            updateThemeToggle(newTheme);
        }

        function updateThemeToggle(theme) {
            const navThemeToggle = document.getElementById('nav-theme-toggle');
            if (navThemeToggle) {
                navThemeToggle.setAttribute('data-theme', theme);
            }
        }

        // Initialize theme on page load
        initTheme();

        // Adjust hero section padding based on nav height
        function adjustHeroForNav() {
            const nav = document.querySelector('nav');
            const hero = document.querySelector('.hero');
            if (nav && hero) {
                const navHeight = nav.offsetHeight;
                hero.style.paddingTop = `${navHeight + 40}px`; // Add 40px buffer
            }
        }

        // Run on load and resize
        adjustHeroForNav();
        window.addEventListener('resize', adjustHeroForNav);

        // Add theme toggle listeners
        document.addEventListener('DOMContentLoaded', () => {
            const navThemeToggle = document.getElementById('nav-theme-toggle');
            
            if (navThemeToggle) {
                navThemeToggle.addEventListener('click', toggleTheme);
            }
        });

        // Listen for system theme changes
        window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
            if (!localStorage.getItem('theme')) {
                const newTheme = e.matches ? 'dark' : 'light';
                document.documentElement.setAttribute('data-theme', newTheme);
                updateThemeToggle(newTheme);
            }
        });

        // Wave animation management
        let waveAnimationActive = false;
        let animationFrameId = null;

        function initWaves() {
            const savedWaveState = localStorage.getItem('wavesEnabled') === 'true';
            if (savedWaveState) {
                enableWaves();
            }
            updateWavesToggle(savedWaveState);
        }

        function toggleWaves() {
            waveAnimationActive = !waveAnimationActive;

            if (waveAnimationActive) {
                enableWaves();
            } else {
                disableWaves();
            }

            localStorage.setItem('wavesEnabled', waveAnimationActive);
            updateWavesToggle(waveAnimationActive);
        }

        function enableWaves() {
            waveAnimationActive = true;
            const container = document.getElementById('wave-container');
            if (container) {
                container.classList.add('active');
                createWaves();
                animateWaves();
            }
        }

        function disableWaves() {
            waveAnimationActive = false;
            const container = document.getElementById('wave-container');
            if (container) {
                container.classList.remove('active');
                container.innerHTML = '';
            }
            if (animationFrameId) {
                cancelAnimationFrame(animationFrameId);
                animationFrameId = null;
            }
        }

        function updateWavesToggle(enabled) {
            const navWavesToggle = document.getElementById('nav-waves-toggle');
            if (navWavesToggle) {
                navWavesToggle.setAttribute('data-waves', enabled ? 'active' : 'inactive');
            }
        }

        function createWaves() {
            const container = document.getElementById('wave-container');
            if (!container) return;

            container.innerHTML = '';
            const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
            svg.setAttribute('viewBox', '0 0 400 200');
            svg.setAttribute('preserveAspectRatio', 'none');
            svg.style.width = '100%';
            svg.style.height = '100%';

            const numLayers = 4;

            for (let i = 0; i < numLayers; i++) {
                const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
                path.setAttribute('class', `wave-path wave-${i}`);
                svg.appendChild(path);
            }

            container.appendChild(svg);
        }

        function generateWavePath(yBase, amplitude, frequency, phase) {
            let d = 'M 0 200 ';
            const numPoints = 40; // Number of points along the wave
            for (let i = 0; i <= numPoints; i++) {
                const x = (i / numPoints) * 400; // Scale to viewBox width
                const normalizedX = i / numPoints; // 0 to 1
                const y = yBase + Math.sin(normalizedX * frequency * Math.PI * 2 + phase) * amplitude;
                d += `L ${x} ${y} `;
            }
            d += 'L 400 200 Z';
            return d;
        }

        function animateWaves() {
            if (!waveAnimationActive) return;

            const container = document.getElementById('wave-container');
            if (!container) return;

            const paths = container.querySelectorAll('path');
            const time = Date.now() * 0.001;

            paths.forEach((path, i) => {
                const yBase = 120 + i * 25;
                const amplitude = 15 + i * 5;
                const frequency = 2 + i * 0.5; // Number of wave cycles
                const phase = time * (0.3 + i * 0.1);

                path.setAttribute('d', generateWavePath(yBase, amplitude, frequency, phase));
            });

            animationFrameId = requestAnimationFrame(animateWaves);
        }

        // Initialize waves on page load
        initWaves();

        // Add waves toggle listeners
        document.addEventListener('DOMContentLoaded', () => {
            const navWavesToggle = document.getElementById('nav-waves-toggle');

            if (navWavesToggle) {
                navWavesToggle.addEventListener('click', toggleWaves);
            }
        });

        // Smooth scrolling for navigation links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                }
            });
        });

        // Fade in animation on scroll
        const observerOptions = {
            threshold: 0.1,
            rootMargin: '0px 0px -50px 0px'
        };

        const observer = new IntersectionObserver(function(entries) {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                }
            });
        }, observerOptions);

        // Observe all fade-in elements
        document.querySelectorAll('.fade-in').forEach(el => {
            observer.observe(el);
        });

        // Add visible class to hero content immediately
        const heroContent = document.querySelector('.hero .fade-in');
        if (heroContent) {
            heroContent.classList.add('visible');
        }

        // Handle image loading states
        document.querySelectorAll('.prose img').forEach(img => {
            const imgElement = img as HTMLImageElement;
            if (imgElement.complete) {
                imgElement.classList.add('loaded');
            } else {
                imgElement.addEventListener('load', () => {
                    imgElement.classList.add('loaded');
                });
                imgElement.addEventListener('error', () => {
                    imgElement.classList.add('loaded');
                    // Optionally show error state
                });
            }
        });
    </script>
</body>

<style is:global>
/* ========== Design Tokens ========== */
:root {
    --font: 'Inter', -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Arial, sans-serif;
    --font-mono: 'SF Mono', Monaco, 'Cascadia Code', Consolas, monospace;

    --primary-color: #1D1D1F;
    --secondary-color: #515154;
    --accent-color: #0071E3;
    --text-light: #86868B;
    --bg-light: #F5F5F7;
    --border-color: #D2D2D7;
    --bg-primary: #FFFFFF;
    --nav-bg: rgba(255, 255, 255, 0.72);
    --card-bg: #FFFFFF;
    --table-stripe: rgba(0, 0, 0, 0.02);
    --table-hover: #F5F5F7;
    --shadow-card: 0 2px 8px rgba(0, 0, 0, 0.06);
    --shadow-card-hover: 0 8px 24px rgba(0, 0, 0, 0.10);
    --loading-bg: linear-gradient(90deg, #F5F5F7 25%, rgba(255, 255, 255, 0.8) 50%, #F5F5F7 75%);
    --radius: 12px;
}

[data-theme='dark'] {
    --primary-color: #F5F5F7;
    --secondary-color: #A1A1A6;
    --accent-color: #2997FF;
    --text-light: #636366;
    --bg-light: #1C1C1E;
    --border-color: #3A3A3C;
    --bg-primary: #000000;
    --nav-bg: rgba(0, 0, 0, 0.72);
    --card-bg: #1C1C1E;
    --table-stripe: rgba(255, 255, 255, 0.04);
    --table-hover: #2C2C2E;
    --shadow-card: 0 2px 8px rgba(0, 0, 0, 0.3);
    --shadow-card-hover: 0 8px 24px rgba(0, 0, 0, 0.4);
    --loading-bg: linear-gradient(90deg, #1C1C1E 25%, rgba(255, 255, 255, 0.03) 50%, #1C1C1E 75%);
    --radius: 12px;
}

/* ========== Base ========== */
* { margin: 0; padding: 0; box-sizing: border-box; }

html { scroll-behavior: smooth; }

body {
    font-family: var(--font);
    line-height: 1.6;
    color: var(--primary-color);
    background: var(--bg-primary);
    font-weight: 400;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
}

.container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
}

/* ========== Navigation ========== */
nav {
    position: fixed;
    top: 0;
    width: 100%;
    background: var(--nav-bg);
    backdrop-filter: saturate(180%) blur(20px);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    z-index: 1000;
    border-bottom: 1px solid var(--border-color);
}

.nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 0;
    gap: 2rem;
}

.logo {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--primary-color);
    text-decoration: none;
    letter-spacing: -0.02em;
    line-height: 1;
}

.nav-links {
    display: flex;
    list-style: none;
    gap: 2rem;
}

.nav-links a {
    text-decoration: none;
    color: var(--secondary-color);
    font-weight: 400;
    font-size: 0.875rem;
    letter-spacing: -0.01em;
    transition: color 0.2s ease;
}

.nav-links a:hover,
.nav-links a.active {
    color: var(--primary-color);
}

.nav-links a.active { font-weight: 500; }

.nav-controls {
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.nav-theme-toggle {
    width: 32px;
    height: 32px;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    background: var(--card-bg);
    color: var(--secondary-color);
    cursor: pointer;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8125rem;
    position: relative;
}

.nav-theme-toggle:hover {
    color: var(--primary-color);
    border-color: var(--secondary-color);
}

.nav-theme-toggle .light-icon,
.nav-theme-toggle .dark-icon {
    position: absolute;
    transition: all 0.3s ease;
}

.nav-theme-toggle .light-icon { opacity: 1; transform: rotate(0deg); }
.nav-theme-toggle .dark-icon  { opacity: 0; transform: rotate(-90deg); }
.nav-theme-toggle[data-theme='dark'] .light-icon { opacity: 0; transform: rotate(90deg); }
.nav-theme-toggle[data-theme='dark'] .dark-icon  { opacity: 1; transform: rotate(0deg); }

.nav-waves-toggle {
    width: 32px;
    height: 32px;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    background: var(--card-bg);
    color: var(--secondary-color);
    cursor: pointer;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8125rem;
}

.nav-waves-toggle:hover {
    color: var(--primary-color);
    border-color: var(--secondary-color);
}

.nav-waves-toggle[data-waves='active'] {
    background: var(--accent-color);
    color: #FFFFFF;
    border-color: var(--accent-color);
}

.nav-waves-toggle[data-waves='active']:hover { opacity: 0.85; }

/* Hamburger */
.nav-hamburger {
    display: none;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    cursor: pointer;
    padding: 4px;
    color: var(--primary-color);
    font-size: 0.9375rem;
}

.nav-hamburger .close-icon { display: none; }
.nav-hamburger.open .open-icon { display: none; }
.nav-hamburger.open .close-icon { display: block; }

.nav-menu {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex: 1;
    justify-content: flex-end;
}

/* ========== Waves ========== */
.wave-container {
    position: fixed;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 200px;
    pointer-events: none;
    z-index: 1;
    opacity: 0;
    transition: opacity 0.5s ease;
}

.wave-container.active { opacity: 1; }
.wave-container svg { width: 100%; height: 100%; }
.wave-path { transition: fill 0.3s ease; }

:root .wave-path.wave-0 { fill: rgba(0, 113, 227, 0.04); }
:root .wave-path.wave-1 { fill: rgba(0, 113, 227, 0.06); }
:root .wave-path.wave-2 { fill: rgba(0, 113, 227, 0.08); }
:root .wave-path.wave-3 { fill: rgba(0, 113, 227, 0.10); }

[data-theme='dark'] .wave-path.wave-0 { fill: rgba(41, 151, 255, 0.04); }
[data-theme='dark'] .wave-path.wave-1 { fill: rgba(41, 151, 255, 0.06); }
[data-theme='dark'] .wave-path.wave-2 { fill: rgba(41, 151, 255, 0.08); }
[data-theme='dark'] .wave-path.wave-3 { fill: rgba(41, 151, 255, 0.10); }

/* ========== Hero ========== */
.hero {
    padding: 160px 0 120px;
    background: var(--bg-primary);
    text-align: center;
}

.hero-content h1 {
    font-size: 5.5rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
    color: var(--primary-color);
    letter-spacing: -0.04em;
    line-height: 1.05;
}

.hero .subtitle {
    font-size: 1.25rem;
    color: var(--secondary-color);
    margin-bottom: 0.75rem;
    font-weight: 400;
    letter-spacing: -0.015em;
}

.hero .tagline {
    font-size: 1rem;
    color: var(--text-light);
    max-width: 520px;
    margin: 0 auto 2.5rem;
    line-height: 1.65;
}

.cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
}

/* ========== Buttons ========== */
.btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8125rem 1.75rem;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.9375rem;
    letter-spacing: -0.01em;
    transition: all 0.2s ease;
    border-radius: 980px;
    border: 1px solid transparent;
}

.btn-primary {
    background: var(--accent-color);
    color: #FFFFFF;
}

.btn-primary:hover { background: #0077ED; }

.btn-secondary {
    background: transparent;
    color: var(--accent-color);
    border-color: var(--accent-color);
}

.btn-secondary:hover {
    background: var(--accent-color);
    color: #FFFFFF;
}

/* ========== Sections ========== */
section { padding: 120px 0; }

.section-title {
    font-size: 2.75rem;
    font-weight: 700;
    text-align: center;
    margin-bottom: 1rem;
    color: var(--primary-color);
    letter-spacing: -0.03em;
    line-height: 1.05;
}

.section-subtitle {
    font-size: 1rem;
    color: var(--secondary-color);
    text-align: center;
    max-width: 560px;
    margin: 0.75rem auto 4rem;
    line-height: 1.6;
    letter-spacing: -0.01em;
}

/* ========== About ========== */
.about-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
}

.about-text {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--secondary-color);
}

.about-text strong {
    color: var(--primary-color);
    font-weight: 600;
}

.about-text p + p { margin-top: 1.25rem; }

.skills-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
}

.skill-category {
    background: var(--bg-light);
    padding: 1.25rem 1.5rem;
    border-radius: var(--radius);
    transition: background 0.2s ease;
}

.skill-category:hover { background: var(--border-color); }

.skill-category h3 {
    color: var(--primary-color);
    font-size: 0.9375rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
    letter-spacing: -0.01em;
}

.skill-category p {
    color: var(--text-light);
    font-size: 0.8125rem;
    line-height: 1.5;
}

/* ========== How I Help ========== */
.how-i-help { background: var(--bg-light); }

.help-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
}

.help-card {
    background: var(--card-bg);
    padding: 2rem;
    border-radius: var(--radius);
    border: 1px solid var(--border-color);
    transition: box-shadow 0.2s ease;
}

.help-card:hover { box-shadow: var(--shadow-card-hover); }

.help-card .icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: rgba(0, 113, 227, 0.08);
    border-radius: 10px;
    font-size: 1.125rem;
    color: var(--accent-color);
    margin-bottom: 1.25rem;
}

[data-theme='dark'] .help-card .icon {
    background: rgba(41, 151, 255, 0.12);
}

.help-card h3 {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--primary-color);
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
    line-height: 1.3;
}

.help-card p {
    color: var(--text-light);
    line-height: 1.6;
    font-size: 0.875rem;
}

/* ========== Achievements ========== */
.achievements { background: var(--bg-primary); }

.achievements-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
}

.achievement-card {
    background: var(--bg-light);
    padding: 2rem;
    border-radius: var(--radius);
    transition: box-shadow 0.2s ease;
}

.achievement-card:hover { box-shadow: var(--shadow-card-hover); }

.achievement-card .icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: rgba(0, 113, 227, 0.08);
    border-radius: 9px;
    font-size: 1rem;
    color: var(--accent-color);
    margin-bottom: 1rem;
}

[data-theme='dark'] .achievement-card .icon {
    background: rgba(41, 151, 255, 0.12);
}

.achievement-card h3 {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--primary-color);
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
}

.achievement-card p {
    color: var(--text-light);
    line-height: 1.6;
    font-size: 0.875rem;
}

/* ========== Case Studies ========== */
.case-studies-grid { display: grid; gap: 1.25rem; }

.case-study {
    background: var(--card-bg);
    border-radius: var(--radius);
    border: 1px solid var(--border-color);
    padding: 2.5rem;
    transition: box-shadow 0.2s ease;
}

.case-study:hover { box-shadow: var(--shadow-card-hover); }

.case-study-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.75rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border-color);
}

.case-study-emoji { font-size: 1.75rem; flex-shrink: 0; }

.case-study-header h2 {
    font-size: 1.375rem;
    font-weight: 600;
    color: var(--primary-color);
    margin: 0;
    letter-spacing: -0.02em;
    line-height: 1.25;
}

.case-study-meta {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
}

.case-study-meta > div {
    background: var(--bg-light);
    border-radius: 8px;
    padding: 1.25rem;
}

.case-study-meta h3 {
    color: var(--accent-color);
    font-size: 0.6875rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
}

.case-study-meta p {
    color: var(--secondary-color);
    line-height: 1.6;
    font-size: 0.875rem;
}

/* ========== Contact ========== */
.contact { background: var(--bg-light); }

.contact-links {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
}

.contact-link {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2rem;
    background: var(--card-bg);
    color: var(--primary-color);
    text-decoration: none;
    border-radius: var(--radius);
    border: 1px solid var(--border-color);
    font-weight: 500;
    font-size: 0.9375rem;
    letter-spacing: -0.01em;
    transition: all 0.2s ease;
    box-shadow: var(--shadow-card);
}

.contact-link:hover {
    box-shadow: var(--shadow-card-hover);
    border-color: var(--accent-color);
    color: var(--accent-color);
}

.contact-link i { font-size: 1rem; color: var(--accent-color); }

/* ========== Footer ========== */
footer {
    background: #1D1D1F;
    color: #F5F5F7;
    text-align: center;
    padding: 2.5rem 0;
    border-top: 1px solid #3A3A3C;
}

