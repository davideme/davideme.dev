---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Navigation from "../../components/Navigation.astro";

export async function getStaticPaths() {
  const drafts = await getCollection("articles", ({ data }) => {
    return data.draft === true;
  });
  return drafts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout
  title={`[DRAFT] ${post.data.title} - Davide Mendolia`}
  description={post.data.description}
  noindex={true}
>
  <Navigation />

  <!-- Draft Banner -->
  <div class="draft-banner">
    <div class="container">
      <span class="draft-label">DRAFT PREVIEW</span>
      <span class="draft-note">This article is not published. Only people with this link can see it.</span>
    </div>
  </div>

  <!-- Article Header -->
  <section class="article-header">
    <div class="container">
      <div class="article-header-content fade-in">
        <div class="breadcrumb">
          <a href="/articles">← Back to Articles</a>
        </div>

        <h1>{post.data.title}</h1>

        {
          post.data.description && (
            <p class="article-subtitle">{post.data.description}</p>
          )
        }

        <div class="article-meta">
          <div class="meta-item">
            <i class="fas fa-user"></i>
            <span>by <strong>{post.data.author}</strong></span>
          </div>

          {
            post.data.publishDate && (
              <div class="meta-item">
                <i class="fas fa-calendar" />
                <time datetime={post.data.publishDate.toISOString()}>
                  {post.data.publishDate.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </time>
              </div>
            )
          }
        </div>

        {
          post.data.tags && post.data.tags.length > 0 && (
            <div class="article-tags">
              {post.data.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )
        }
      </div>
    </div>
  </section>

  <!-- Article Content -->
  <section class="article-content">
    <div class="container">
      <article class="prose">
        <Content />
      </article>
    </div>
  </section>
</Layout>

<style>
  .draft-banner {
    background: #f59e0b;
    color: #1a1a1a;
    padding: 0.75rem 0;
    position: sticky;
    top: 4rem;
    z-index: 100;
    margin-top: 4rem;
  }

  .draft-banner .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .draft-label {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: #1a1a1a;
    color: #f59e0b;
    padding: 0.2rem 0.5rem;
    border-radius: 3px;
    white-space: nowrap;
  }

  .draft-note {
    font-size: 0.8125rem;
    font-weight: 500;
  }

  /* Article Header */
  .article-header {
    background: var(--bg-primary);
    padding: 6rem 0 4rem;
    position: relative;
    z-index: 1;
    border-bottom: 1px solid var(--border-color);
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .breadcrumb {
    margin-bottom: 2rem;
  }

  .breadcrumb a {
    color: var(--secondary-color);
    text-decoration: none;
    font-size: 0.8125rem;
    font-weight: 400;
    letter-spacing: 0.03em;
    transition: color 0.2s ease;
  }

  .breadcrumb a:hover {
    color: var(--primary-color);
  }

  .article-header-content h1 {
    font-size: 3.5rem;
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    color: var(--primary-color);
    letter-spacing: -0.04em;
  }

  .article-subtitle {
    font-size: 1.0625rem;
    color: var(--text-light);
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 680px;
    font-weight: 300;
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    margin-bottom: 2rem;
    color: var(--text-light);
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    letter-spacing: 0.02em;
  }

  .meta-item i {
    color: var(--accent-color);
    width: 14px;
  }

  .meta-item strong {
    color: var(--primary-color);
    font-weight: 500;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    background: transparent;
    color: var(--secondary-color);
    padding: 0.35rem 0.75rem;
    border: 1px solid var(--border-color);
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  /* Article Content */
  .article-content {
    padding: 5rem 0;
  }

  .prose {
    max-width: 720px;
    margin: 0 auto;
    line-height: 1.85;
    font-size: 1.0625rem;
    color: var(--secondary-color);
  }

  .prose :global(h1),
  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4),
  .prose :global(h5),
  .prose :global(h6) {
    font-weight: 700;
    line-height: 1.2;
    margin: 3rem 0 1rem 0;
    color: var(--primary-color);
    letter-spacing: -0.025em;
  }

  .prose :global(h1) { font-size: 2.5rem; }
  .prose :global(h2) { font-size: 2rem; }
  .prose :global(h3) { font-size: 1.625rem; }
  .prose :global(h4) { font-size: 1.25rem; }

  .prose :global(p) {
    margin: 1.5rem 0;
    color: var(--secondary-color);
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 1.5rem 0;
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    margin: 0.5rem 0;
    color: var(--secondary-color);
  }

  .prose :global(blockquote) {
    border-left: 2px solid var(--accent-color);
    background: var(--bg-light);
    padding: 1.25rem 1.75rem;
    margin: 2.5rem 0;
    border-radius: 0 var(--radius) var(--radius) 0;
    font-style: italic;
    color: var(--secondary-color);
  }

  .prose :global(code) {
    background: var(--bg-light);
    padding: 0.2rem 0.45rem;
    border-radius: 4px;
    font-family: 'SF Mono', Monaco, 'Cascadia Code', monospace;
    font-size: 0.875em;
    color: var(--primary-color);
    border: 1px solid var(--border-color);
  }

  .prose :global(pre) {
    background: var(--bg-light);
    padding: 1.5rem;
    overflow-x: auto;
    margin: 2rem 0;
    border-radius: var(--radius);
    border: 1px solid var(--border-color);
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
    border: none;
    color: var(--primary-color);
  }

  .prose :global(a) {
    color: var(--primary-color);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--border-color);
    transition: text-decoration-color 0.2s ease;
  }

  .prose :global(a:hover) {
    text-decoration-color: var(--accent-color);
  }

  .prose :global(strong) {
    font-weight: 500;
    color: var(--primary-color);
  }

  .prose :global(em) { font-style: italic; }

  @media (max-width: 768px) {
    .draft-banner .container {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }

    .article-header {
      padding: 4rem 0 3rem;
    }

    .article-header-content h1 {
      font-size: 2.25rem;
    }

    .article-meta {
      flex-direction: column;
      gap: 1rem;
    }

    .container {
      padding: 0 1.25rem;
    }

    .prose {
      font-size: 1rem;
    }

    .prose :global(h1) { font-size: 2rem; }
    .prose :global(h2) { font-size: 1.625rem; }
    .prose :global(h3) { font-size: 1.375rem; }
  }
</style>
