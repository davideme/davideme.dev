---
import advisorData from '../data/framework-advisor.yaml';
import AdvisorIcon from './advisor/AdvisorIcon.astro';
import QuestionStep from './advisor/QuestionStep.astro';
import ResultCard from './advisor/ResultCard.astro';
import FrameworkColumn from './advisor/FrameworkColumn.astro';
import OutOfScope from './advisor/OutOfScope.astro';
import './FrameworkAdvisorWidget.css';

const { questions } = advisorData;
const fwKeys = ['react', 'vue', 'angular', 'svelte', 'solid'];

// Icons the runtime script injects dynamically (nav, caveats, why, verdict, copy
// feedback, header restart). Static parts render their icons via <AdvisorIcon> directly.
const spriteIcons = [
  'arrow-left', 'arrow-right', 'triangle-exclamation', 'route', 'chevron-down',
  'copy', 'check', 'rotate-left', 'circle-check', 'code-merge',
  'arrows-split-up-and-left', 'ellipsis',
];
---

<!-- Hidden sprite — the few icons the script injects at runtime, rendered at build time -->
<div id="advisor-icon-sprites" style="display:none" aria-hidden="true">
  {spriteIcons.map(name => (
    <span id={`advisor-icon-${name}`}><AdvisorIcon name={name} /></span>
  ))}
</div>

<section class="advisor advisor--card" id="framework-advisor-root" aria-label="Frontend framework advisor">
  <header class="advisor__head">
    <div class="advisor__brand">
      <span class="advisor__spark" aria-hidden="true">
        <AdvisorIcon name="wand-magic-sparkles" />
      </span>
      <div>
        <span class="advisor__kicker">Interactive tool</span>
        <h2 class="advisor__title">Which framework fits your SaaS?</h2>
      </div>
    </div>
    <div class="advisor__head-restart" style="display:none"></div>
  </header>

  <div class="advisor__progress-mount"></div>

  <div class="advisor__stage-mount">
    {questions.map((q, i) => (
      <div class:list={["stage", { "enter-fwd": i === 0 }]} data-panel="q" data-step={i} hidden={i !== 0}>
        <div class="stage__inner"><QuestionStep q={q} index={i} /></div>
      </div>
    ))}

    {fwKeys.map(key => (
      <div class="stage" data-panel="result" data-rec={key} hidden>
        <div class="stage__inner"><ResultCard fwKey={key} /></div>
      </div>
    ))}

    <div class="stage" data-panel="comparison" hidden>
      <div class="stage__inner"></div>
    </div>

    <div class="stage" data-panel="oos" hidden>
      <div class="stage__inner"><OutOfScope /></div>
    </div>
  </div>

  <div class="advisor__nav-mount"></div>

  <!-- Parts bin — comparison column bodies cloned by the script -->
  <div class="advisor__parts" hidden>
    {fwKeys.map(key => <FrameworkColumn fwKey={key} />)}
  </div>
</section>

<!-- Questionnaire content + framework facts, read by the widget script for the
     recommendation algorithm and the few runtime-built fragments -->
<script is:inline type="application/json" id="advisor-data" set:html={JSON.stringify(advisorData)} />

<script>
  import './FrameworkAdvisorWidget.js';
</script>
