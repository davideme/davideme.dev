---
// One question step, rendered statically from the YAML. Covers all four kinds
// (options / scale / cards / picker). Selection highlight, roving tabindex and the
// backend free-text value are applied at runtime by the widget script — this markup
// is the inert, declarative skeleton.
import AdvisorIcon from './AdvisorIcon.astro';

interface Props {
  q: any;
  index: number;
}

const { q } = Astro.props;
const cols = q.columns || 1;
const noneVal = q.noneValue || 'none';
---

<div class="qstep" data-question={q.id}>
  <div class="qstep__head">
    <span class="eyebrow">{q.eyebrow}</span>
    <h3 class="qstep__title">{q.title}</h3>
    <p class="qstep__sub">{q.sub}</p>
  </div>

  {q.kind === 'options' && (
    <div class={`optgrid optgrid--c${cols}`} role="radiogroup" aria-label={q.title}>
      {q.options.map((opt, i) => (
        <button
          type="button"
          role="radio"
          aria-checked="false"
          tabindex={i === 0 ? '0' : '-1'}
          class:list={["opt", "opt--row", { "opt--escape": opt.escape }]}
          data-select={opt.v}
        >
          {opt.icon && <span class="opt__chip"><AdvisorIcon name={opt.icon} /></span>}
          <span class="opt__text">
            <span class="opt__label">{opt.label}</span>
            {opt.desc && <span class="opt__desc">{opt.desc}</span>}
          </span>
          <span class="opt__radio" aria-hidden="true"><AdvisorIcon name="check" /></span>
        </button>
      ))}
    </div>
  )}

  {q.kind === 'scale' && (
    <div class="scale" role="radiogroup">
      <div class="scale__track" aria-hidden="true"></div>
      {q.options.map((opt, i) => (
        <button
          type="button"
          role="radio"
          aria-checked="false"
          tabindex={i === 0 ? '0' : '-1'}
          data-select={opt.v}
          class="scale__stop"
        >
          <span class="scale__dot" aria-hidden="true"></span>
          <span class="scale__label">{opt.label}</span>
          <span class="scale__desc">{opt.desc}</span>
        </button>
      ))}
    </div>
  )}

  {q.kind === 'cards' && (
    <div class="pgrid" role="radiogroup" aria-label={q.title}>
      {q.options.map((opt, i) => (
        <button
          type="button"
          role="radio"
          aria-checked="false"
          tabindex={i === 0 ? '0' : '-1'}
          class="pcard"
          data-select={opt.v}
        >
          {opt.tag && <span class="pcard__tag">{opt.tag}</span>}
          <span class="pcard__label">{opt.label}</span>
          {opt.lede && <span class="pcard__lede">{opt.lede}</span>}
          <span class="pcard__desc">{opt.desc}</span>
          <span class="pcard__check" aria-hidden="true"><AdvisorIcon name="check" /></span>
        </button>
      ))}
    </div>
  )}

  {q.kind === 'picker' && (
    <div class="picker">
      {q.groups.map(g => (
        <div class="picker__group">
          <span class="picker__glabel">{g.label}</span>
          <div class="picker__chips" role="radiogroup" aria-label={g.label}>
            {g.options.map(opt => (
              <button type="button" role="radio" aria-checked="false" data-select={opt.v} class="chip">{opt.label}</button>
            ))}
          </div>
        </div>
      ))}
      <button type="button" data-select={noneVal} class="picker__none">{q.noneLabel || 'No preference yet'}</button>
    </div>
  )}

  {q.id === 'backend' && (
    <div class="freetext" data-freetext hidden>
      <input
        type="text"
        id="fa-freetext"
        value=""
        placeholder="Tell us what you use (optional) — won't block your result"
        aria-label="Describe your backend stack"
      />
    </div>
  )}
</div>

<style>
  /* ── Question step ────────────────────────────────────────────────── */
  .qstep { display: flex; flex-direction: column; gap: 22px; }
  .qstep__head { display: flex; flex-direction: column; gap: 8px; }
  .qstep__title {
    font-size: 25px; font-weight: 700; letter-spacing: -0.025em;
    line-height: 1.2; color: var(--fg-1); margin: 0;
  }
  .qstep__sub { font-size: var(--fs-sm); color: var(--fg-2); line-height: 1.55; max-width: 58ch; margin: 0; }

  /* ── Option grid ──────────────────────────────────────────────────── */
  .optgrid { display: grid; gap: 10px; }
  .optgrid--c1 { grid-template-columns: 1fr; }
  .optgrid--c2 { grid-template-columns: 1fr 1fr; }
  @media (max-width: 520px) { .optgrid--c2 { grid-template-columns: 1fr; } }

  .opt {
    display: flex; align-items: center; gap: 14px; text-align: left; width: 100%;
    background: var(--card-bg); border: 1px solid var(--border-1);
    border-radius: var(--radius); padding: 15px 16px; cursor: pointer;
    transition: border-color .18s, box-shadow .18s, background .18s;
    font-family: inherit; color: inherit;
  }
  .opt:hover { border-color: var(--fg-3); box-shadow: var(--shadow-card); }
  .opt:focus-visible { outline: none; border-color: var(--accent); box-shadow: 0 0 0 4px var(--accent-tint); }
  /* .is-sel is applied at runtime by the widget script */
  .opt.is-sel { border-color: var(--accent); background: var(--accent-tint); }
  .opt.is-sel:hover { box-shadow: none; }
  .opt__chip {
    flex: none; width: 40px; height: 40px; border-radius: 10px;
    background: var(--accent-tint); color: var(--accent);
    display: flex; align-items: center; justify-content: center; font-size: 16px;
    transition: background .18s, color .18s;
  }
  .opt.is-sel .opt__chip { background: var(--accent); color: #fff; }
  .opt__text { flex: 1; display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .opt__label { font-size: var(--fs-sm); font-weight: 600; color: var(--fg-1); letter-spacing: -0.01em; }
  .opt__desc  { font-size: var(--fs-2xs); color: var(--fg-3); line-height: 1.45; }
  .opt__radio {
    flex: none; width: 22px; height: 22px; border-radius: 50%;
    border: 1.5px solid var(--border-1);
    display: flex; align-items: center; justify-content: center; color: #fff; font-size: 10px;
    transition: all .18s; opacity: 0;
  }
  .opt.is-sel .opt__radio { opacity: 1; background: var(--accent); border-color: var(--accent); }
  .opt--escape { border-style: dashed; }
  .opt--escape .opt__chip { background: var(--bg-2); color: var(--fg-3); }
  .opt--escape.is-sel .opt__chip { background: var(--accent); color: #fff; }

  /* ── Scale (3-point) ──────────────────────────────────────────────── */
  .scale {
    position: relative; display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px;
  }
  .scale__track {
    position: absolute; top: 19px; left: 12%; right: 12%;
    height: 2px; background: var(--border-1); z-index: 0;
  }
  .scale__stop {
    position: relative; z-index: 1; display: flex; flex-direction: column;
    align-items: center; gap: 8px; background: transparent; border: none;
    cursor: pointer; padding: 8px 6px; border-radius: var(--radius);
    font-family: inherit; transition: background .18s;
  }
  .scale__stop:hover { background: var(--bg-1); }
  .scale__dot {
    width: 20px; height: 20px; border-radius: 50%; background: var(--card-bg);
    border: 2px solid var(--border-1); transition: all .18s;
  }
  .scale__stop:hover .scale__dot { border-color: var(--fg-3); }
  .scale__stop.is-sel .scale__dot {
    border-color: var(--accent); background: var(--accent);
    box-shadow: 0 0 0 5px var(--accent-tint);
  }
  .scale__label {
    font-size: var(--fs-2xs); font-weight: 600; color: var(--fg-1);
    text-align: center; line-height: 1.25; letter-spacing: -0.01em;
  }
  .scale__stop.is-sel .scale__label { color: var(--accent); }
  .scale__desc { font-size: 11.5px; color: var(--fg-3); text-align: center; line-height: 1.35; }
  .scale__stop:focus-visible { outline: none; }
  .scale__stop:focus-visible .scale__dot { box-shadow: 0 0 0 5px var(--accent-tint); border-color: var(--accent); }
  @media (max-width: 520px) {
    .scale { grid-template-columns: 1fr; gap: 6px; }
    .scale__track { display: none; }
    .scale__stop { flex-direction: row; justify-content: flex-start; gap: 12px; text-align: left; padding: 10px; }
    .scale__label, .scale__desc { text-align: left; }
  }

  /* ── Philosophy / ecosystem cards ────────────────────────────────── */
  .pgrid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
  @media (max-width: 640px) { .pgrid { grid-template-columns: 1fr; } }
  .pcard {
    position: relative; display: flex; flex-direction: column; gap: 7px;
    text-align: left; background: var(--card-bg); border: 1px solid var(--border-1);
    border-radius: var(--radius); padding: 18px 16px; cursor: pointer;
    transition: border-color .18s, box-shadow .18s, transform .18s; font-family: inherit;
  }
  .pcard:hover { border-color: var(--fg-3); box-shadow: var(--shadow-card-hover); transform: translateY(-2px); }
  .pcard:focus-visible { outline: none; border-color: var(--accent); box-shadow: 0 0 0 4px var(--accent-tint); }
  .pcard.is-sel { border-color: var(--accent); box-shadow: 0 0 0 1px var(--accent); }
  .pcard__tag {
    font-size: 10.5px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em;
    color: var(--accent); background: var(--accent-tint); padding: 4px 8px;
    border-radius: 6px; align-self: flex-start;
  }
  .pcard__label { font-size: var(--fs-h4); font-weight: 700; color: var(--fg-1); letter-spacing: -0.015em; line-height: 1.25; }
  .pcard__lede  { font-size: var(--fs-2xs); font-weight: 500; color: var(--fg-2); }
  .pcard__desc  { font-size: var(--fs-2xs); color: var(--fg-3); line-height: 1.5; }
  .pcard__check {
    position: absolute; top: 14px; right: 14px; width: 22px; height: 22px; border-radius: 50%;
    background: var(--accent); color: #fff; display: flex; align-items: center;
    justify-content: center; font-size: 10px; opacity: 0; transform: scale(.6);
    transition: all .18s;
  }
  .pcard.is-sel .pcard__check { opacity: 1; transform: scale(1); }

  /* ── Picker (Q9) ──────────────────────────────────────────────────── */
  .picker { display: flex; flex-direction: column; gap: 18px; }
  .picker__group { display: flex; flex-direction: column; gap: 10px; }
  .picker__glabel {
    font-size: var(--fs-3xs); font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.06em; color: var(--fg-3);
  }
  .picker__chips { display: flex; flex-wrap: wrap; gap: 8px; }
  .chip {
    font-family: inherit; font-size: var(--fs-sm); font-weight: 500; color: var(--fg-1);
    background: var(--card-bg); border: 1px solid var(--border-1); border-radius: 980px;
    padding: 9px 18px; cursor: pointer; transition: all .18s; letter-spacing: -0.01em;
  }
  .chip:hover { border-color: var(--accent); color: var(--accent); }
  .chip:focus-visible { outline: none; border-color: var(--accent); box-shadow: 0 0 0 4px var(--accent-tint); }
  .chip.is-sel { background: var(--accent); border-color: var(--accent); color: #fff; }
  .picker__none {
    font-family: inherit; font-size: var(--fs-sm); font-weight: 500; color: var(--fg-2);
    background: var(--bg-1); border: 1px dashed var(--border-1); border-radius: var(--radius);
    padding: 13px; cursor: pointer; transition: all .18s; text-align: center; width: 100%;
  }
  .picker__none:hover { border-color: var(--fg-3); color: var(--fg-1); }
  .picker__none.is-sel { border-style: solid; border-color: var(--accent); color: var(--accent); background: var(--accent-tint); }

  /* ── Free-text input ──────────────────────────────────────────────── */
  .freetext input {
    width: 100%; font-family: inherit; font-size: var(--fs-sm); color: var(--fg-1);
    background: var(--card-bg); border: 1px solid var(--border-1); border-radius: var(--radius);
    padding: 13px 16px; transition: all .18s; margin-top: 10px;
  }
  .freetext input:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 4px var(--accent-tint); }
  .freetext input::placeholder { color: var(--fg-3); }
</style>
